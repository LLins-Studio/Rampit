# Stellar (Soroban) deployment — copy to .env:  cp .env.example .env

# testnet | mainnet
STELLAR_NETWORK=mainnet

# Mainnet Soroban RPC (required if CLI mainnet network is misconfigured)
STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
STELLAR_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"

# Deployer: Stellar CLI identity name (secret in ~/.config/stellar/identity/)
STELLAR_SOURCE=rampit-deploy

# Or deployer secret (S...); if set, overrides STELLAR_SOURCE for signing
# STELLAR_SECRET_KEY=

# Public G-addresses (NOT private keys). Leave empty to use deployer address.
# Change later on-chain via set_admin / set_relayer (admin must sign).
RAMPIT_ADMIN=
RAMPIT_RELAYER=
RAMPIT_FEE_BPS=50

# Optional — fill in after deploy
# STELLAR_CONTRACT_ID=

# --- EVM (Foundry) — Celo + Base + BNB; use EVM_* or CELO_* (Stellar keeps G-address RAMPIT_*) ---
# EVM_RAMPIT_ADMIN=0x...
# EVM_RAMPIT_RELAYER=0x...
# EVM_DEPLOYER_PRIVATE_KEY=0x...
# CELO_RPC_URL=https://forno.celo.org
# BASE_RPC_URL=https://mainnet.base.org
# BNB_RPC_URL=https://bsc-dataseed.binance.org
# RAMPIT_FEE_BPS=50
# CELOSCAN_API_KEY=   # optional verify
# BASESCAN_API_KEY=
# BSCSCAN_API_KEY=
# Deploy all:  cd contracts/evm && bash deploy-mainnet.sh

# --- Solana (Anchor) mainnet deploy ---
# Path to deployer keypair (needs ~3+ SOL on mainnet-beta)
# SOLANA_KEYPAIR=~/.config/solana/id.json
# RAMPIT_FEE_BPS=50
# RAMPIT_RELAYER=   # optional; defaults to deployer pubkey at initialize
