# Copy this file to .env.local and add your actual frontend API base URL or email service endpoint.
# Do NOT commit .env.local to source control.

# Local proxy configuration.
# The app now uses its own /api/auth/login and /api/auth/login/verify routes.
# If you want to proxy to a different live API base, set it here.
RAMPIT_API_BASE=https://api.rampit.xyz/api/v1

# Frontend API base used by the auth modal. If you want to use the live API directly, leave this as the default value.
NEXT_PUBLIC_API_BASE=https://api.rampit.xyz/api/v1

# If you want to use your own local email service endpoint, set this to the full URL.
# Example: EMAIL_SERVICE_URL=http://localhost:4000/api/send-otp
EMAIL_SERVICE_URL=

RESEND_API_KEY=your_resend_api_key_here
