# Copy to .env.local (never commit .env.local)

# Stellar — public (client-safe)
NEXT_PUBLIC_STELLAR_CONTRACT_ID=
NEXT_PUBLIC_STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon.stellar.org

# EVM escrow proxy (same address on Celo / Base / BNB)
NEXT_PUBLIC_EVM_ESCROW_PROXY=
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BNB_RPC_URL=https://bsc-dataseed.binance.org

# Server-only — set in Netlify / local .env.local (no NEXT_PUBLIC_)
ADMIN_SECRET_KEY=
ADMIN_API_SECRET=
EVM_RELAYER_PRIVATE_KEY=

# Optional auth proxy (defaults to https://api.rampit.xyz/api/v1)
# RAMPIT_API_BASE=
